{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "1.2.0",
  "description": "__MSG_appDesc__",
  "default_locale": "en",
  "permissions": ["tabs", "tabGroups", "storage", "alarms", "bookmarks"],
  "host_permissions": [
    "https://api.github.com/*",
    "https://gist.githubusercontent.com/*"
  ],
  "optional_host_permissions": ["https://*/*", "http://*/*"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "__MSG_appName__",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
